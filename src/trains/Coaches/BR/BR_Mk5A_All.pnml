    0: sw_graphics_BR_Mk5A_Nova3_TPE;
    1: sw_graphics_BR_Mk5A_Nova3_Chiltern; }

// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR_Mk5A_Nova3_cargo_subtype_text, cargo_subtype){
	0:	return string(str_TPE);
    1:  return string(str_ChilternExplorer);
       return CB_RESULT_NO_TEXT; }

// length switch
switch(FEAT_TRAINS, SELF, sw_length_BR_Mk5A_Nova3, position_in_articulated_veh % 3) {
	1: 6;
        4; }


// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR_Mk5A_Nova3, position_in_vehid_chain % 15) {
    0: 276 * param_pax; // all the capacity - (vehid chain number)
    1..14: 1 * param_pax;
    // total 291
}


// speed switch
switch(FEAT_TRAINS, SELF, sw_speed_BR_Mk5A_Nova3, param_max_speed) {
    0: 125; // operational speed
    1: 140; // design speed
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR_Mk5A_Nova3, extra_callback_info1) {
	1..14: return item_BR_Mk5A_Nova3;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }


// unit definition
item (FEAT_TRAINS, item_BR_Mk5A_Nova3, 12190) {
    property {
        // common properties
        name:                           string(STR_NAME_BR_Mk5A_Nova3);
        // variant_group:                  ; // unit ID or item
		// extra_flags:                    bitmask(VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2017,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					57; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          125 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        weight:                         215 ton;
        dual_headed:                    0;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR_Mk5A_Nova3;
        purchase:                       sw_purchase_BR_Mk5A_Nova3;

        // internal code
        name:                           sw_name_BR_Mk5A_Nova3;
        length:                         sw_length_BR_Mk5A_Nova3;
        articulated_part:               sw_articulated_BR_Mk5A_Nova3;
        speed:                          sw_speed_BR_Mk5A_Nova3() * 1609 / 1000;  
        purchase_cargo_capacity:        return (19 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR_Mk5A_Nova3;
        cost_factor:                    4239;
        running_cost_factor:            2818;
        cargo_subtype_text:             sw_BR_Mk5A_Nova3_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_coach,
                                                    string(str_coach_Train_Set),
                                                    string(str_BR_Mk5A_liveries)));
    }
}

