// purchase year switch
switch(FEAT_TRAINS, PARENT, sw_BR_Mk1_BSO_purchase_sprite, current_year) {
	// 1948..1965: spriteset_BR_Mk1_BSO_BR_Blue_purchase;
    1966..2002: spriteset_BR_Mk1_BSO_BR_Blue_purchase;
	spriteset_BR_Mk1_BSO_BR_Maroon_purchase; }

// livery switch
switch(FEAT_TRAINS, SELF, sw_livery_BR_Mk1_BSO, cargo_subtype) {
    0:  sw_loadstack_BR_Mk1_BSO_BR_Maroon;
    1:  sw_loadstack_BR_Mk1_BSO_BR_BnC;
    2:  sw_loadstack_BR_Mk1_BSO_BR_Southern_Green;
    3:  sw_loadstack_BR_Mk1_BSO_BR_CnC;
    4:  sw_loadstack_BR_Mk1_BSO_BR_Blue; }

switch(FEAT_TRAINS, SELF, sw_livery_BR_Mk1_BSO_REV, cargo_subtype) {
    0: sw_loadstack_BR_Mk1_BSO_BR_Maroon_REV;
    1: sw_loadstack_BR_Mk1_BSO_BR_BnC_REV;
    2: sw_loadstack_BR_Mk1_BSO_BR_Southern_Green_REV;
    3: sw_loadstack_BR_Mk1_BSO_BR_CnC_REV;
    4: sw_loadstack_BR_Mk1_BSO_BR_Blue_REV; }

// random switch
random_switch(FEAT_TRAINS, SELF, random_choose_reverse_BR_Mk1_BSO_BR_Maroon) {
    1: sw_livery_BR_Mk1_BSO;
    1: sw_livery_BR_Mk1_BSO_REV; }

// position switch
switch(FEAT_TRAINS, SELF, sw_check_position_BR_Mk1_BSO_BR_Maroon, position_in_consist) {
    1..7: sw_livery_BR_Mk1_BSO;
        return random_choose_reverse_BR_Mk1_BSO_BR_Maroon; }

// reverse switch
switch(FEAT_TRAINS, SELF, sw_check_reverse_BR_Mk1_BSO_BR_Maroon, num_vehs_in_consist >= 6 ? position_in_consist_from_end : -1) {
    1: sw_livery_BR_Mk1_BSO_REV;
        return sw_check_position_BR_Mk1_BSO_BR_Maroon; }

// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR_Mk1_BSO_cargo_subtype_text, cargo_subtype) {
    0:  return string(str_BRMaroon);
    1:  return string(str_BRCarmCream);
    2:  return string(str_BRMalachite);
    3:  return string(str_BRChocCream);
    4:  return string(str_BRBlueGrey);
        return CB_RESULT_NO_TEXT;
}

switch(FEAT_TRAINS, SELF, sw_graphics_BR_Mk1_BSO, position_in_articulated_veh % 3) {
    1: return sw_check_reverse_BR_Mk1_BSO_BR_Maroon;
        spriteset_empty; }

// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR_Mk1_BSO, position_in_articulated_veh % 3) {
    0: 38 * param_pax;
    1: 1 * param_pax;
    2: sw_capacity_BR_Mk1_B;
} // total 39 pax, 36 mail

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR_Mk1_BSO, extra_callback_info1) {
    1: return item_BR_Mk1_BSO;
    2: return item_BR_Mk1_B;
        return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

// unit definition
item (FEAT_TRAINS, item_BR_Mk1_BSO, 12006) { // Diagram 183, 184 BR Mk1 BSO
    property {
        // common properties
        name:                           string(STR_NAME_BR_Mk1_BSO);
        variant_group:                  item_BR_Mk1_Header; // unit ID or item
		extra_flags:                    bitmask(VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(1955,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // refittable_cargo_classes:        bitmask(CC_PIECE_GOODS, CC_EXPRESS, CC_HAZARDOUS, CC_REFRIGERATED, CC_NON_POURABLE, CC_NEO_BULK, CC_OVERSIZED);	
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        loading_speed:					10;
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          100 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        weight:                         34 ton;
        dual_headed:                    0;
        length:                         4;
    }

    graphics {
        // graphics
        default:                        sw_graphics_BR_Mk1_BSO;
        purchase:                       sw_BR_Mk1_BSO_purchase_sprite;
        
        // internal code
        articulated_part:               sw_articulated_BR_Mk1_BSO;
        purchase_cargo_capacity:        return (19 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR_Mk1_BSO;
        cost_factor:                    875;
        running_cost_factor:            1331;
        cargo_subtype_text:             sw_BR_Mk1_BSO_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_coach,
                                                    string(str_coach_BSO),
                                                    string(str_BR_Mk1_liveries)));
    }
}