switch(FEAT_TRAINS, PARENT, sw_reverse_BR220_TMSRB_TMSO_XC_Refurb_Concept, vehicle_is_reversed) {
    1:  sw_loadstack_BR220_TMSO_XC_Refurb_Concept_REV; 
        sw_loadstack_BR220_TMSRB_XC_Refurb_Concept; }

// graphics
switch(FEAT_TRAINS, SELF, sw_graphics_BR220_Virgin, position_in_vehid_chain % 12) {
    1:  sw_reverse_BR220_DMSO_DMFO_Virgin;
    4:  sw_reverse_BR220_TMSO_TMSRB_Virgin;
    7:  sw_reverse_BR220_TMSRB_TMSO_Virgin;
    10: sw_reverse_BR220_DMFO_DMSO_Virgin;
        spriteset_empty; }
        
switch(FEAT_TRAINS, SELF, sw_graphics_BR220_XC, position_in_vehid_chain % 12) {
    1:  sw_reverse_BR220_DMSO_DMFO_XC;
    4:  sw_reverse_BR220_TMSO_TMSRB_XC;
    7:  sw_reverse_BR220_TMSRB_TMSO_XC;
    10: sw_reverse_BR220_DMFO_DMSO_XC;
        spriteset_empty; }

switch(FEAT_TRAINS, SELF, sw_graphics_BR220_XC_Pride, position_in_vehid_chain % 12) {
    1:  sw_reverse_BR220_DMSO_DMFO_XC_Pride;
    4:  sw_reverse_BR220_TMSO_TMSRB_XC_Pride;
    7:  sw_reverse_BR220_TMSRB_TMSO_XC_Pride;
    10: sw_reverse_BR220_DMFO_DMSO_XC_Pride;
        spriteset_empty; }

switch(FEAT_TRAINS, SELF, sw_graphics_BR220_XC_Refurb, position_in_vehid_chain % 12) {
    1:  sw_reverse_BR220_DMSO_DMFO_XC_Refurb;
    4:  sw_reverse_BR220_TMSO_TMSRB_XC_Refurb;
    7:  sw_reverse_BR220_TMSRB_TMSO_XC_Refurb;
    10: sw_reverse_BR220_DMFO_DMSO_XC_Refurb;
        spriteset_empty; }

switch(FEAT_TRAINS, SELF, sw_graphics_BR220_XC_Refurb_Concept, position_in_vehid_chain % 12) {
    1:  sw_reverse_BR220_DMSO_DMFO_XC_Refurb_Concept;
    4:  sw_reverse_BR220_TMSO_TMSRB_XC_Refurb_Concept;
    7:  sw_reverse_BR220_TMSRB_TMSO_XC_Refurb_Concept;
    10: sw_reverse_BR220_DMFO_DMSO_XC_Refurb_Concept;
        spriteset_empty; }

// livery
switch(FEAT_TRAINS, SELF, sw_livery_BR220, cargo_subtype) {
    0:  sw_graphics_BR220_Virgin;
    1:  sw_graphics_BR220_XC;
    2:  sw_graphics_BR220_XC_Pride;
    3:  sw_graphics_BR220_XC_Refurb;
    4:  sw_graphics_BR220_XC_Refurb_Concept; }

// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR220_cargo_subtype_text, cargo_subtype){
	0:	return string(str_Virgin);
    1:  return string(str_XC);
    2:  return string(str_XC_Pride);
    3:  return string(str_XC_Refurb);
    4:  return string(str_XC_Refurb_Concept);
       return CB_RESULT_NO_TEXT; }

// length switch
switch(FEAT_TRAINS, SELF, sw_length_BR220, position_in_articulated_veh % 12) {
	1:  7;
    4:  6;
    7:  6;
    10: 7;
        return 4; }

// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR220, position_in_vehid_chain % 12) {
    0: 189 * param_pax; // all the capacity - (vehid chain number)
    1..11: 1 * param_pax;
    // total 200
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR220, extra_callback_info1) {
	1..11: return item_BR220;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }

// unit definition
item (FEAT_TRAINS, item_BR220, 2201) {
    property {
        // common properties
        name:                           string(STR_NAME_BR220);
        // variant_group:                  ; // unit ID or item
		// extra_flags:                    bitmask(VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2001,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					45; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          125 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        power:                          3000 hp;
        weight:                         186 ton;
        engine_class:                   ENGINE_CLASS_DIESEL;
        dual_headed:                    0;
        air_drag_coefficient:           0.05;
        tractive_effort_coefficient:    0.1;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR220;
        visual_effect_and_powered:      sw_FX_BR220_Diesel;
        purchase:                       sw_purchase_sprite_BR220;
        sound_effect:                   sw_sound_diesel_220;

        // internal code
        length:                         sw_length_BR220;
        articulated_part:               sw_articulated_BR220;
        purchase_cargo_capacity:        return (16 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR220;
        cost_factor:                    243;
        running_cost_factor:            10093;
        cargo_subtype_text:             sw_BR220_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_dmu),
                                                    string(str_usage_expr_pax),
                                                    string(str_BR220_liveries)));
    }
}

