// livery name switch
switch(FEAT_TRAINS, SELF, sw_BR221_cargo_subtype_text, cargo_subtype) {
    0:  return string(str_Virgin);
    1:  return string(str_VirginSilk);
    2:  return string(str_AvantiWestCoast);
    3:  return string(str_XC);
    4:  return string(str_GCLined); }
    
// length switch
switch(FEAT_TRAINS, SELF, sw_length_BR221_5, position_in_articulated_veh % 15) {
	1:  7;
    4:  6;
    7:  6;
    10: 6;
    13: 7;
        return 4; }

switch(FEAT_TRAINS, SELF, sw_length_BR221_4, position_in_articulated_veh % 12) {
	1:  7;
    4:  6;
    7:  6;
    10: 7;
        return 4; }

// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR221_5, position_in_vehid_chain % 15) {
    0: 249 * param_pax; // all the capacity - (vehid chain number)
    1..14: 1 * param_pax;
    // total 262
}

switch(FEAT_TRAINS, SELF, sw_capacity_BR221_4, position_in_vehid_chain % 12) {
    0: 181 * param_pax; // all the capacity - (vehid chain number)
    1..11: 1 * param_pax;
    // total 192
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR221_5, extra_callback_info1) {
	1..14: return item_BR221_5;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }

// unit definition
item (FEAT_TRAINS, item_BR221_5, 2210) {
    property {
        // common properties
        name:                           string(STR_NAME_BR221_5);
        // variant_group:                  ; // unit ID or item
		// extra_flags:                    bitmask(VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2002,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					57; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          125 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        power:                          3750 hp;
        weight:                         283 ton;
        engine_class:                   ENGINE_CLASS_DIESEL;
        dual_headed:                    0;
        air_drag_coefficient:           0.05;
        tractive_effort_coefficient:    0.1;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR221_5;
        visual_effect_and_powered:      sw_FX_BR221_5_Diesel;
        purchase:                       sw_purchase_sprite_BR221;
        sound_effect:                   sw_sound_diesel_220;

        // internal code
        length:                         sw_length_BR221_5;
        articulated_part:               sw_articulated_BR221_5;
        purchase_cargo_capacity:        return (17 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR221_5;
        cost_factor:                    292;
        running_cost_factor:            11400;
        cargo_subtype_text:             sw_BR221_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_dmu),
                                                    string(str_usage_expr_pax),
                                                    string(str_BR221_liveries)));
    }
}


