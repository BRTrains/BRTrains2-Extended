// unit definition
item (FEAT_TRAINS, item_BR101_3, 1013) {
    property {
        // common properties
        name:                           string(STR_NAME_BR101_3);
        variant_group:                  item_BR101; // unit ID or item
		extra_flags:                    bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB, VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(1956,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [];
        misc_flags: 					bitmask(TRAIN_FLAG_SPRITE_STACK);
        // misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        loading_speed:					27;
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          70 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        power:                          600 hp;
        weight:                         90 ton;
        engine_class:                   ENGINE_CLASS_DIESEL;
        dual_headed:                    0;
        air_drag_coefficient:           0.05;
        tractive_effort_coefficient:    0.25;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR101_3car;
        visual_effect_and_powered:      sw_FX_BR101_3car_Diesel;
        purchase:                       sw_BR101_purchase_sprite;
        sound_effect:                   sw_sound_diesel_25;

        // internal code
        length:                         sw_length_BR101;
        articulated_part:               sw_articulated_BR101_3car;
        purchase_cargo_capacity:        return ( 24 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR101_3car;
        cost_factor:                    152;
        running_cost_factor:            3735;
        cargo_subtype_text:             sw_BR101_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;
        // colour_mapping:                 switch_generic_recolour;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_dmu),
                                                    string(str_usage_pax),
                                                    string(str_BR101_liveries)));
    }
}

