switch(FEAT_TRAINS, SELF, sw_loadstack_BR802_TS_GWR_Leading, [ STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ] ) {
    0: spriteset_BR802_TS_GWR_Leading;
    1: spritegroup_BR802_MC_GWR_Leading_Loading; }

switch(FEAT_TRAINS, SELF, sw_loadstack_BR802_TS_GWR_Leading_REV, [ STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ] ) {
