// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR802_0, extra_callback_info1) {
	1..14: return item_BR802_0;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }


// unit definition
item (FEAT_TRAINS, item_BR802_0, 8020) {
    property {
        // common properties
        name:                           string(STR_NAME_BR802_0);
		extra_flags:                    bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2017,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					56; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          125 mph;
        refit_cost:                     0;
        track_type:                     [RAIL, ELRL];
        power:                          3640 hp;
        weight:                         243 ton;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        dual_headed:                    0;
        air_drag_coefficient:           0.05;
        tractive_effort_coefficient:    0.1;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR802_0;
        visual_effect_and_powered:      sw_FX_BR800_5car;
        purchase:                       sw_spritestack_BR800_3_purchase;
        sound_effect:                   sw_sound_BR800;

        // internal code
        length:                         sw_length_BR800_5car;
        articulated_part:               sw_articulated_BR802_0;
        speed:                          sw_speed_BR800() * 1609 / 1000;  
        purchase_cargo_capacity:        return (21 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR802_0;
        cost_factor:                    286;
        running_cost_factor:            9913;
        cargo_subtype_text:             sw_BR802_0_1_GWR_cargo_subtype_text; 
        power:                          sw_power_BR802_5car;
        colour_mapping:                 return PALETTE_CC_FIRST;
        // colour_mapping:                 switch_generic_recolour;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_bmu),
                                                    string(str_usage_expr_pax),
                                                    string(str_BR800_0_liveries)));
    }
}



