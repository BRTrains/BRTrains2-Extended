switch(FEAT_TRAINS, SELF, sw_loadstack_BR800_3_TS_GWR_Leading, [ STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ] ) {
    0: spriteset_BR800_3_TS_GWR_Leading;
    1: spritegroup_BR800_3_MF_GWR_Leading_Loading; }

switch(FEAT_TRAINS, SELF, sw_loadstack_BR800_3_TS_GWR_Leading_REV, [ STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 1 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ] ) {
    0: spriteset_BR800_3_TS_GWR_Leading_REV;
    1: spritegroup_BR800_3_MF_GWR_Leading_Loading_REV; }

// purchase sprite
switch(FEAT_TRAINS, SELF, sw_spritestack_BR800_3_purchase, [STORE_TEMP((getbits(extra_callback_info1, 8, 8) < 2 ? CB_FLAG_MORE_SPRITES : 0) | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8)]) {
    0: spriteset_BR800_3_DPTS_GWR_purchase;
    1: spriteset_BR800_DPTS_GWR_Nose_Closed_purchase; 
    2: spriteset_BR800_panto_down_purchase; }

// graphics switch
switch(FEAT_TRAINS, SELF, sw_graphics_BR800_3_GWR, position_in_articulated_veh % 27) {
    1:  sw_loadstack_BR800_3_DPTS_GWR;
    4:  sw_loadstack_BR800_3_MS_GWR_Leading;
    7:  sw_loadstack_BR800_3_MS_GWR_Leading_NoBatteries;
    10: sw_loadstack_BR800_3_TS_GWR_Leading;
    13: sw_loadstack_BR800_3_MS_GWR_Middle;
    16: sw_loadstack_BR800_3_TS_GWR_Leading_REV;
    19: sw_loadstack_BR800_3_MS_GWR_Leading_NoBatteries_REV;
    22: sw_loadstack_BR800_3_MF_GWR_Leading_REV;
    25: sw_loadstack_BR800_3_DPTF_GWR_REV;
        spriteset_empty; }
        
// livery switch
switch(FEAT_TRAINS, SELF, sw_livery_BR800_3, cargo_subtype) {
    0:  sw_graphics_BR800_3_GWR; }

// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR800_3_GWR_cargo_subtype_text, cargo_subtype){
	0:	return string(str_GWR);
       return CB_RESULT_NO_TEXT; }


// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR800_3, position_in_vehid_chain % 27) {
    0: 624 * param_pax; // all the capacity - (vehid chain number)
    1..26: 1 * param_pax;
    // total 650
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR800_3, extra_callback_info1) {
	1..26: return item_BR800_3;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }

// unit definition
item (FEAT_TRAINS, item_BR800_3, 8003) {
    property {
        // common properties
        name:                           string(STR_NAME_BR800_3);
        variant_group:                  item_BR800_0; // unit ID or item
		extra_flags:                    bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB, VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2017,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					101; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          125 mph;
        refit_cost:                     0;
        track_type:                     [RAIL, ELRL];
        power:                          6070 hp;
        weight:                         438 ton;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        dual_headed:                    0;
        air_drag_coefficient:           0.06;
        tractive_effort_coefficient:    0.07;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR800_3;
        visual_effect_and_powered:      sw_FX_BR800_9car;
        purchase:                       sw_spritestack_BR800_3_purchase;
        sound_effect:                   sw_sound_BR800;

        // internal code
        length:                         sw_length_BR800_9car;
        articulated_part:               sw_articulated_BR800_3;
        speed:                          sw_speed_BR800() * 1609 / 1000;  
        purchase_cargo_capacity:        return (25 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR800_3;
        cost_factor:                    478;
        running_cost_factor:            13331;
        cargo_subtype_text:             sw_BR800_3_GWR_cargo_subtype_text; 
        power:                          sw_power_BR800_9car;
        colour_mapping:                 return PALETTE_CC_FIRST;
        // colour_mapping:                 switch_generic_recolour;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_bmu),
                                                    string(str_usage_expr_pax),
                                                    string(str_BR800_0_liveries)));
    }
}