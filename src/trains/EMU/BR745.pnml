// unit definition
item (FEAT_TRAINS, item_BR745_0, 7450) {
    property {
        // common properties
        name:                           string(STR_NAME_BR745_0);
        extra_flags:                    bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB);

        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2018,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        // non_refittable_cargo_classes:    bitmask();
        cargo_allow_refit:               [PASS, TOUR];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					135; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          100 mph;
        refit_cost:                     0;
        track_type:                     ELRL;
        power:                          7000 hp;
        weight:                         263 ton;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        dual_headed:                    0;
        air_drag_coefficient:           0.06;
        tractive_effort_coefficient:    0.15;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR745_0;
        visual_effect_and_powered:      sw_FX_BR745_Electric;
        purchase:                       spriteset_BR745_DMFO_GA_purchase;
        sound_effect:                   sw_sound_electric_88;

        // internal code
        length:                         sw_length_BR745;
        articulated_part:               sw_articulated_BR745_0;
        purchase_cargo_capacity:        return (19 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR745_0;
        cost_factor:                    507;
        running_cost_factor:            13628;
        cargo_subtype_text:             sw_BR745_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_emu),
                                                    string(str_usage_pax),
                                                    string(str_BR745_liveries)));
    }
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR745_1, extra_callback_info1) {
	1..35: return item_BR745_1;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }

