// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR313_cargo_subtype_text, cargo_subtype) {
    0:  return string(str_BRBlueGrey);
    1:  return string(str_NSE);
    2:  return string(str_Silverlink);
    3:  return string(str_LO_exSilverlink);
    4:  return string(str_FCC);
    5:  return string(str_GGN);
    6:  return string(str_Southern);
    7:  return string(str_SouthernCoastway);
    8:  return string(str_BRBlueHeritage);
        return CB_RESULT_NO_TEXT; }

// capacity switch
switch(FEAT_TRAINS, SELF, sw_capacity_BR313, position_in_vehid_chain % 3) {
    0: 224 * param_pax; // all the capacity - (vehid chain number)
    1..8: 1 * param_pax;
    // total 232
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR313, extra_callback_info1) {
	1..8: return item_BR313;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS; }


// unit definition
item (FEAT_TRAINS, item_BR313, 3130) {
    property {
        // common properties
        name:                           string(STR_NAME_BR313);
        // variant_group:                  ; // unit ID or item
		extra_flags:                    bitmask(VEHICLE_FLAG_TRAIN_HAS_CAB);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(1976,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		refittable_cargo_classes:        bitmask(CC_PASSENGERS);
        cargo_allow_refit:               [PASS, TOUR];
        // cargo_disallow_refit:            [LVST];
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 1;
        // for MUs, loading speed is multiplied by number of carriages * 0.75
        loading_speed:					34; // Standard Class
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          75 mph;
        refit_cost:                     0;
        track_type:                     [ELRL, BR_3RDR];
        power:                          880 hp;
        weight:                         105 ton;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        dual_headed:                    0;
        air_drag_coefficient:           0.05;
        tractive_effort_coefficient:    0.09;
        length:                         4;
    }

    graphics {
        // graphics
        default:                        sw_livery_BR313;
        visual_effect_and_powered:      sw_FX_BR313_Electric;
        purchase:                       spriteset_BR313_DMSO_NSE_purchase;
        sound_effect:                   sw_sound_electric_GEC;

        // internal code
        articulated_part:               sw_articulated_BR313;
        purchase_cargo_capacity:        return (25 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR313;
        cost_factor:                    207;
        running_cost_factor:            4973;
        cargo_subtype_text:             sw_BR313_cargo_subtype_text; 
        // power:                          sw_power_BR313;
        colour_mapping:                 return PALETTE_CC_FIRST;
        // colour_mapping:                 switch_generic_recolour;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_emu),
                                                    string(str_usage_pax),
                                                    string(str_BR313_liveries)));
    }
}


