    0:  sw_BR313_BR_Blue;
    1:  sw_BR313_NSE;
    2:  sw_BR313_Silverlink;
    3:  sw_BR313_LO_exSL;
    4:  sw_BR313_FCC;
    5:  sw_BR313_GN_exFCC;
