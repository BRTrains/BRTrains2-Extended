        articulated_part:               sw_articulated_BR800_2;
        speed:                          sw_speed_BR800() * 1609 / 1000;  
        purchase_cargo_capacity:        return (20 * param_pax); // divide by number of articulated parts and floor
        cargo_capacity:                 sw_capacity_BR800_2;
        cost_factor:                    275;
        running_cost_factor:            9903;
        cargo_subtype_text:             sw_BR800_LNER_cargo_subtype_text; 
        power:                          sw_power_BR800_5car;
        colour_mapping:                 return PALETTE_CC_FIRST;
        // colour_mapping:                 switch_generic_recolour;

        // purchase menu text
        additional_text:                return( string(str_purchase_loco_with_liveries,
                                                    string(str_purchase_type_bmu),
                                                    string(str_usage_expr_pax),
                                                    string(str_BR800_1_2_liveries)));
    }
}
