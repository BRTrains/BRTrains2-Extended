    alternative_sprites(spriteset_BR_CHO_BR_Bauxite_purchase, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_1x_32bpp.png", "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_1x_mask.png")
