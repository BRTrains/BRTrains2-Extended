
// basic sprite
spriteset(spriteset_BR_CHO_BR_Bauxite, "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_1x_8bpp.png")
    { template_58trains_1x(0,0) }

    alternative_sprites(spriteset_BR_CHO_BR_Bauxite, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_1x_32bpp.png", "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_1x_mask.png")
    { template_58trains_1x(0,0) }

    alternative_sprites(spriteset_BR_CHO_BR_Bauxite, ZOOM_LEVEL_IN_2X, BIT_DEPTH_32BPP, "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_2x_32bpp.png", "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_2x_mask.png")
    { template_58trains_2x(0,0) }

    alternative_sprites(spriteset_BR_CHO_BR_Bauxite, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP, "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_4x_32bpp.png", "gfx/Wagons/BR_CHO/BR_CHO_BR_Bauxite_4x_mask.png")
    { template_58trains_4x(0,0) }

