    { template_purchase(0,0) }


// livery switch
random_switch(FEAT_TRAINS, SELF, sw_random_choose_Grey_Blue_BR_IIA) {
    1:  spriteset_BR_IIA_D_Grey_Blue_Angles;
    1:  spriteset_BR_IIA_D_Grey_Blue_Curve; }

switch(FEAT_TRAINS, SELF, sw_livery_BR_IIA_D, cargo_subtype) {
    0: sw_random_choose_Grey_Blue_BR_IIA;
    1: spriteset_BR_IIA_D_Blue;
}

// livery name refit switch
switch(FEAT_TRAINS, SELF, sw_BR_IIA_D_cargo_subtype_text, cargo_subtype){
	0:	return string(STR_LIVERY_BRANDED, string(str_col_Grey), string(str_col_Blue));
    1:  return string(STR_LIVERY, string(str_comp_gen_priv_owner), string(str_col_Blue));
       return CB_RESULT_NO_TEXT;
}


// graphics switch
switch(FEAT_TRAINS, SELF, sw_graphics_BR_IIA_D, position_in_articulated_veh % 3) {
	1: return sw_livery_BR_IIA_D;
	    spriteset_empty; }



// length switch
switch(FEAT_TRAINS, SELF, sw_length_BR_IIA_D, position_in_articulated_veh % 3) {
	1: 3;
	    4; }

// speed switch
switch(FEAT_TRAINS, SELF, sw_speed_BR_IIA_D, param_max_speed) {
    0: 75; // operational speed
    1: 100; // design speed
}

// articulation switch
switch(FEAT_TRAINS, SELF, sw_articulated_BR_IIA_D, extra_callback_info1) {
	1..2: return item_BR_IIA_D;
		return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}


// BR_IIA_D definition
item (FEAT_TRAINS, item_BR_IIA_D, 12806) {
    property {
        // common properties
        name:                           string(STR_NAME_BR_IIA_D);
        // variant_group:                  ; // BR_IIA_D ID or item
		// extra_flags:                    bitmask(VEHICLE_FLAG_DISABLE_NEW_VEHICLE_MESSAGE, VEHICLE_FLAG_DISABLE_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_EXCLUSIVE_PREVIEW, VEHICLE_FLAG_SYNC_VARIANT_RELIABILITY);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(2013,01,01); 
        model_life:                     VEHICLE_NEVER_EXPIRES;
        vehicle_life: 					40;
        retire_early: 					-10;							
        reliability_decay: 				20;
        
		// refittable_cargo_classes:       bitmask(CC_COVERED, CC_POWDERIZED);	
        // non_refittable_cargo_classes:   bitmask(CC_NON_POTABLE, CC_NON_POURABLE);
        cargo_allow_refit:              [CBLK, CLAY, CMNT, KAOL, OLSD, PEAT, POTA, COBL, QLME, SALT, SASH];
        // cargo_disallow_refit:           [FERT, KAOL, WDPR, WOOL];
        default_cargo_type:             PEAT;
        misc_flags: 					bitmask(TRAIN_FLAG_AUTOREFIT, TRAIN_FLAG_SPRITE_STACK);
        cargo_capacity:                 24 * param_freight;
        loading_speed:				    5; // All freight / Locomotive
        running_cost_base:			    RUNNING_COST_STEAM;		

        //specific properties
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        speed:                          75 mph;
        refit_cost:                     0;
        track_type:                     RAIL;
        power:                          0 hp;
        weight:                         30 ton;
        dual_headed:                    0;
        length:                         8;
    }

    graphics {
        // graphics
        default:                        sw_graphics_BR_IIA_D;
        purchase:                       spriteset_BR_IIA_D_Grey_Blue_Curve_purchase;
       
        // internal code
        length:                         sw_length_BR_IIA_D;
        articulated_part:               sw_articulated_BR_IIA_D;
        speed:                          sw_speed_BR_IIA_D() * 1609 / 1000;  
        purchase_cargo_capacity:        return (5 * param_freight); // divide by number of articulated parts and floor
        cost_factor:                    1274;
        running_cost_factor:            1340;
        cargo_subtype_text:             sw_BR_IIA_D_cargo_subtype_text; 
        colour_mapping:                 return PALETTE_CC_FIRST;

        // purchase menu text
        additional_text:                return( string(str_purchase_wagon,
                                                    string(str_BR_IIA_D_liveries)));
    }
}

