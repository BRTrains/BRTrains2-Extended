    { template_118trains_1x(0,0) }

    alternative_sprites(spriteset_BR_IIA_D_Blue, ZOOM_LEVEL_IN_2X, BIT_DEPTH_32BPP, "gfx/Wagons/BR_IIA_D/BR_IIA_D_Blue_2x_32bpp.png", "gfx/Wagons/BR_IIA_D/BR_IIA_D_Blue_2x_mask.png")
    { template_118trains_2x(0,0) }

